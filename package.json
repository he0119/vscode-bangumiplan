{
  "name": "bangumiplan",
  "displayName": "BangumiPlan",
  "description": "A VS Code extension for Bangumi planning with clickable BGM IDs",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/he0119/vscode-bangumiplan.git"
  },
  "publisher": "he0119",
  "engines": {
    "vscode": "^1.103.0"
  },
  "icon": "images/icon.png",
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "bangumi"
  ],
  "main": "./extension.js",
  "scripts": {
    "test": "vscode-test"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  },
  "contributes": {
    "languages": [
      {
        "id": "bangumiplan",
        "aliases": [
          "BangumiPlan",
          "bangumiplan"
        ],
        "extensions": [
          ".bp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bangumiplan",
        "scopeName": "source.bangumiplan",
        "path": "./syntaxes/bangumiplan.tmLanguage.json"
      }
    ]
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.3.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
